# ── AI Factory 后端（独立 FastAPI :8129）· 配置模板 ───────────────────────
# 复制为 .env 后按需修改。
ENVIRONMENT=development

# production 必填。Creator nginx 会为写接口注入该 header；独立直调需发送
# X-Creator-API-Key。建议使用 `openssl rand -hex 32` 生成。
# CREATOR_API_KEY=

# 仅确有跨域直连后端时配置；生产环境禁止 `*`。正常 Creator 页面走 nginx 同源代理。
AIFACTORY_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

# 本地 PostgreSQL（与 sim_backend 同库）
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aifactory_simulation

# 本地文件存储根（用户上传 + 缩略图；通过 /static 挂载对外）
# 留空 = 默认用 aifactory_backend/storage（跟盘符无关）。要自定义再取消注释填绝对路径。
# AIFACTORY_STORAGE_ROOT=d:/Sim2Real/storage

# ZIP 上传安全上限（以下为默认值，可按模型规模调整）
# AIFACTORY_ZIP_MAX_ENTRIES=10000
# AIFACTORY_ZIP_MAX_SINGLE_FILE_BYTES=268435456
# AIFACTORY_ZIP_MAX_TOTAL_UNCOMPRESSED_BYTES=1073741824
# AIFACTORY_ZIP_MAX_COMPRESSION_RATIO=200
# AIFACTORY_ZIP_MAX_ARCHIVE_BYTES=536870912

# Phase 2 合并后：schema 由 sim_backend 拥有，纯消费
AIFACTORY_CREATE_ALL=false
