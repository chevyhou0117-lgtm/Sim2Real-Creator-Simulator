# Backend API base (Vite proxy 默认转发 /api → 后端，故无需在此配置 backend URL)

# Omniverse Kit FastAPI service (3D 视口控制端点 — /ov/select-and-focus 等)
# Kit 单进程独立部署，默认监听 8011；上线/部署改成实际地址
VITE_KIT_API_URL=http://localhost:8011

# Omniverse Kit 串流页面（WebRTC viewer）
# PlanConfig 中间视口会以 iframe 形式嵌入；未配置时降级到 2D 假图
# 例：本地 streaming app → http://localhost:8211 ；NVCF 或 K8s 部署 → 该服务的实际 URL
VITE_KIT_STREAM_URL= 
