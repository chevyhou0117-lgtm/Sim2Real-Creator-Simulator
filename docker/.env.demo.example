# ─────────────────────────────────────────────────────────────────────────────
# docker-compose.demo.yml 的可选覆盖项。
# 用法：复制为 docker/.env（compose 自动读取同目录 .env），按需改值后 build/up。
#   Copy-Item docker/.env.demo.example docker/.env
# 改了带 VITE_ 前缀的项后，必须重新 build sim-frontend（这些值在构建期烤进静态文件）：
#   docker compose -f docker/docker-compose.demo.yml build sim-frontend
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL 密码（同时作用于 PG 容器与两个后端的连接串）。演示可留默认，交付务必改强密码。
POSTGRES_PASSWORD=postgres

# aifactory 资产/缩略图/USD 库在【宿主机】的根目录。默认 docker/storage-data（空目录即可启动）。
# 有真实 31GB 资产库时指向它，例如：
# AIFACTORY_STORAGE_HOST=d:/Sim2Real/storage
AIFACTORY_STORAGE_HOST=./storage-data

# ── 以下 3 个是【浏览器端】访问 Kit / 后端的地址，本机演示用 localhost 即可 ──────────
# Kit 控制面（/ov 视口控制 + /kit/playback 回放）。kit.ts 默认回退 8011；若你的 Kit 在 8233 暴露则改 8233。
VITE_KIT_API_URL=http://localhost:8011
# 3D 视口开关：非空=启用「直连 WebRTC」（前端直接连 Kit 的 media:12333/signal:12334，**不再需要 5183 串流页**）；
# 留空=降级 2D mock。实际连接目标(Kit 主机/端口)在 源码/sim_frontend/stream.config.json（默认 127.0.0.1:12333/12334，
# 远程多机访问时把其中 server 改成 Kit 宿主 IP）。
VITE_KIT_STREAM_URL=enabled

# 串流方式：direct=前端直连 WebRTC（默认，不需要 5183 页）；iframe=回退到原 5183 串流页（逃生门）。
# 直连暂时不通时，设 VITE_KIT_STREAM_MODE=iframe 并把上面 VITE_KIT_STREAM_URL 改成真实 5183 地址（如 http://localhost:5183），
# 然后 `docker compose -f docker/docker-compose.demo.yml up -d --build sim-frontend` 即可一键回到可用状态。
VITE_KIT_STREAM_MODE=direct
# Kit 服务端回拉事件用的后端直连地址，必须 = compose 发布到宿主的 sim-backend 端口（8000）。
VITE_BACKEND_DIRECT_URL=http://localhost:8000
