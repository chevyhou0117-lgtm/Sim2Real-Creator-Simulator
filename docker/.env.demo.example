# ─────────────────────────────────────────────────────────────────────────────
# docker-compose.demo.yml 的可选覆盖项。
# 用法：复制为 docker/.env（compose 自动读取同目录 .env），按需改值后 build/up。
#   Copy-Item docker/.env.demo.example docker/.env
# 跨机 / 换 Kit IP：现在只需设下面的 KIT_HOST_IP 再 `up -d`（容器启动时按它重写 runtime-config.js），
#   【无需 rebuild】。下方 VITE_* 仅作构建期默认/回退，本机演示用 localhost 即可。
# ─────────────────────────────────────────────────────────────────────────────

# ★★ 跨机访问必改：运行 Kit 的宿主机【局域网可达 IP】（远程浏览器据此直连 WebRTC 12333/12334，
#    sim 前端据此调 /ov 与后端）。本机演示留 127.0.0.1。
#    改完执行：docker compose -f docker/docker-compose.demo.yml up -d   （不必 --build）
KIT_HOST_IP=127.0.0.1
# sim 前端的 Kit /ov 控制端口（=8233）与 sim 后端发布端口；一般不用改。
# ★ 这是 sim 前端用的 Kit；aifactory 前端的 Kit upstream 由下方 KIT_API_UPSTREAM 运行期配置。
KIT_API_PORT=8233
BACKEND_PORT=8000

# PostgreSQL 密码（同时作用于 PG 容器与两个后端的连接串）。演示可留默认，交付务必改强密码。
POSTGRES_PASSWORD=postgres

# Creator 登录与后端写接口共用的部署密钥。必须生成后填写，留空时 Compose 会拒绝启动：
#   openssl rand -hex 32
# 浏览器访问 :8081 时用户名默认 creator、密码为该密钥。
CREATOR_AUTH_USERNAME=creator
CREATOR_API_KEY=

# Kit 容器中的 aifactory.service.setup 【只读取这个完整连接串】，不会读取 DB_HOST/DB_PORT。
# 必须与上面的 POSTGRES_PASSWORD 保持一致；若密码含 @ : / # % 等 URL 保留字符，需先 URL 编码。
# 主机名固定写 sim-postgres，因为 Kit 会加入与 compose 相同的 Docker 网络。
AIFACTORY_DATABASE_URL=postgresql+asyncpg://postgres:postgres@sim-postgres:5432/aifactory_simulation

# Compose 与独立 Kit 容器共享的 Docker 网络名。一般不要改；若修改，run-kit-linux.sh 会读取同一值。
SIM2REAL_DOCKER_NETWORK=sim2real-demo_default

# aifactory backend(:8128) 的明确 CORS 白名单，英文逗号分隔，禁止使用 *。
# Creator 正常流量经 :8081/nginx 同源访问，因此远程客户端 IP 通常无需加入这里。
AIFACTORY_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

# Creator nginx 的 Kit 控制面 upstream。
# Linux 容器化 Kit 保持 sim2real:8011；Windows/宿主原生 Kit 改为 host.docker.internal:8011。
KIT_API_UPSTREAM=sim2real:8011

# aifactory 资产/缩略图/USD 库在【宿主机】的根目录（仅管挂载源＝文件写到哪）。
# 默认 docker/storage-data（空目录即可启动）。有真实 31GB 资产库时指向它，
# 必须 = Kit 挂载/读取的同一目录，且属主为 UID 1000（sudo chown -R 1000:1000 <目录>）。例如：
AIFACTORY_STORAGE_HOST=/opt/sim2real/storage

# 新建工厂项目写进数据库 root_usd_path 的路径前缀（Kit 视角的形式，与上面挂载源已解耦）。
# 默认 ../storage：Kit 拼到自己的 USD_ROOT(/storage) 下归一化后正好落回 /storage/...，
# 任何机器都成立，一般【不要设】。仅当 Kit 的 USD 根目录不叫 storage 时才需要调整。
# AIFACTORY_USD_DB_PREFIX=../storage

# ── 以下 3 个是【浏览器端】访问 Kit / 后端的地址，本机演示用 localhost 即可 ──────────
# sim 前端的 Kit 控制面（/ov 视口控制 + /kit/playback 回放）。sim 的 Kit 在 8233（与 aifactory 的 8011 分开）。
# 仅作构建期回退；运行期以上面的 KIT_API_PORT 注入为准。
VITE_KIT_API_URL=http://localhost:8233
# 3D 视口开关：非空=启用「直连 WebRTC」（前端直接连 Kit 的 media:12333/signal:12334，**不再需要 5183 串流页**）；
# 留空=降级 2D mock。实际连接目标(Kit 主机/端口)在 源码/sim_frontend/stream.config.json（默认 127.0.0.1:12333/12334，
# 远程多机访问时把其中 server 改成 Kit 宿主 IP）。
VITE_KIT_STREAM_URL=enabled

# 串流方式：direct=前端直连 WebRTC（默认，不需要 5183 页）；iframe=回退到原 5183 串流页（逃生门）。
# 直连暂时不通时，设 VITE_KIT_STREAM_MODE=iframe 并把上面 VITE_KIT_STREAM_URL 改成真实 5183 地址（如 http://localhost:5183），
# 然后 `docker compose -f docker/docker-compose.demo.yml up -d --build sim-frontend` 即可一键回到可用状态。
VITE_KIT_STREAM_MODE=direct
# Kit 服务端回拉事件用的后端直连地址，必须 = compose 发布到宿主的 sim-backend 端口（8000）。
VITE_BACKEND_DIRECT_URL=http://localhost:8000
